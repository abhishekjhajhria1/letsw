# Copy to .env and fill in. Get the DB values from your Neon project.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/lwts?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/lwts?sslmode=require"
SESSION_SECRET="a-long-random-string"

# Web Push — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""   # same value as VAPID_PUBLIC_KEY

# protects the reminder cron endpoint
CRON_SECRET="a-random-string"
